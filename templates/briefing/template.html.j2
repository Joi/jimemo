{#- briefing — a memo/status template: masthead, optional stat row,
    prose body, optional dated/headed sections. Extends the toolkit
    page skeleton; components used: page-header, stat-tile. -#}
{% extends "page.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
{{ ui.page_header(title,
     kicker=kicker|default(none),
     subtitle=subtitle|default(none),
     meta=([date] if date|default(none) else [])) }}

{% set stat_items = stats|default([]) %}
{% if stat_items %}
{{ ui.stat_row(stat_items) }}
{% endif %}

<div class="jm-prose">
{{ body }}
{% for s in sections|default([]) %}
<h2>{{ s.heading }}</h2>
{{ s.body }}
{% endfor %}
</div>
{% endblock %}

{% block footer %}Rendered with jimemo{% endblock %}
